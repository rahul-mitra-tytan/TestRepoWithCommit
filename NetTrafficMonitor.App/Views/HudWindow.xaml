<Window x:Class="NetTrafficMonitor.Views.HudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetTraffic HUD"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        Width="260" Height="90"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- Transparent versions of theme brushes for HUD -->
        <SolidColorBrush x:Key="HudBackground" Opacity="0.85" Color="{Binding Source={StaticResource BgBrush}, Path=Color}"/>
        <SolidColorBrush x:Key="HudBorder" Color="{Binding Source={StaticResource SurfaceBrush}, Path=Color}"/>
        <SolidColorBrush x:Key="HudTextSecondary" Color="{Binding Source={StaticResource TextBrush}, Path=Color}"/>
        <SolidColorBrush x:Key="HudDownloadColor" Color="{Binding Source={StaticResource GreenBrush}, Path=Color}"/>
        <SolidColorBrush x:Key="HudUploadColor" Color="{Binding Source={StaticResource OrangeBrush}, Path=Color}"/>
    </Window.Resources>

    <Border CornerRadius="8" Background="{StaticResource HudBackground}" BorderBrush="{StaticResource HudBorder}" BorderThickness="1"
            Padding="12">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ClickThrough}" Value="True">
                        <Setter Property="IsHitTestVisible" Value="False"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="{Binding Title}"
                       FontSize="11" Foreground="{StaticResource HudTextSecondary}" Margin="0,0,0,4"
                       HorizontalAlignment="Center"/>

            <!-- Download -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="↓" Foreground="{StaticResource HudDownloadColor}"
                       FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DownloadText"
                       Text="0 Mb/s" Foreground="{StaticResource HudDownloadColor}"
                       FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>

            <!-- Upload -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="↑" Foreground="{StaticResource HudUploadColor}"
                       FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="UploadText"
                       Text="0 Mb/s" Foreground="{StaticResource HudUploadColor}"
                       FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
        </Grid>
    </Border>
</Window>
