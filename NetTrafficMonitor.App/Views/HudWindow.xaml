<Window x:Class="NetTrafficMonitor.Views.HudWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="NetTraffic HUD" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False" Topmost="True" Width="300" Height="200" WindowStartupLocation="Manual">
    <Window.Resources>
        <!-- Reuse theme brushes directly so HUD stays in sync when theme changes -->
        <SolidColorBrush x:Key="HudBackground" Color="{Binding Source={StaticResource BgBrush}, Path=Color}" Opacity="0.85"/>
        <SolidColorBrush x:Key="HudBorder" Color="{Binding Source={StaticResource SurfaceBrush}, Path=Color}"/>
        <SolidColorBrush x:Key="HudTextSecondary" Color="{Binding Source={StaticResource TextBrush}, Path=Color}"/>
        <SolidColorBrush x:Key="HudDownloadColor" Color="{Binding Source={StaticResource GreenBrush}, Path=Color}"/>
        <SolidColorBrush x:Key="HudUploadColor" Color="{Binding Source={StaticResource OrangeBrush}, Path=Color}"/>

        <ContextMenu x:Key="HudContextMenu">
            <MenuItem Header="Show Speed" Click="OnSpeedViewClick"/>
            <MenuItem Header="Show Graph" Click="OnGraphViewClick"/>
            <Separator/>
            <MenuItem Header="Units">
                <MenuItem Header="bps" Click="OnUnitClick" Tag="bps"/>
                <MenuItem Header="KB/s" Click="OnUnitClick" Tag="KB/s"/>
                <MenuItem Header="MB/s" Click="OnUnitClick" Tag="MB/s"/>
                <MenuItem Header="GB/s" Click="OnUnitClick" Tag="GB/s"/>
                <MenuItem Header="Auto" Click="OnUnitClick" Tag="auto"/>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Close" Click="OnCloseClick"/>
        </ContextMenu>

        <!-- Theme-aware context menu -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <StackPanel>
                                <ItemsPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="8,4,16,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.ContextMenu>
        <StaticResource ResourceKey="HudContextMenu"/>
    </Window.ContextMenu>

    <Border CornerRadius="8" Background="{StaticResource HudBackground}" BorderBrush="{StaticResource HudBorder}" BorderThickness="1" Padding="12">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ClickThrough}" Value="True">
                        <Setter Property="IsHitTestVisible" Value="False"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Speed View -->
            <StackPanel x:Name="SpeedView" Grid.RowSpan="3" Grid.ColumnSpan="2">
                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Network Speed" FontSize="11" Foreground="{StaticResource HudTextSecondary}" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="↓" Foreground="{StaticResource HudDownloadColor}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DownloadText" Text="0 Mb/s" Foreground="{StaticResource HudDownloadColor}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="↑" Foreground="{StaticResource HudUploadColor}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="UploadText" Text="0 Mb/s" Foreground="{StaticResource HudUploadColor}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Graph View (hidden by default) -->
            <Canvas x:Name="GraphView" Grid.RowSpan="3" Grid.ColumnSpan="2" Visibility="Collapsed">
                <Path x:Name="DownloadGraph" Stroke="{StaticResource HudDownloadColor}" StrokeThickness="2"/>
                <Path x:Name="UploadGraph" Stroke="{StaticResource HudUploadColor}" StrokeThickness="2"/>
            </Canvas>
        </Grid>
    </Border>
</Window>
