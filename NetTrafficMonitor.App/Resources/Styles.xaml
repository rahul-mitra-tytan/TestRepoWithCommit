<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:NetTrafficMonitor.Converters">

    <!-- Converters -->
    <local:ThemeToStringConverter x:Key="ThemeToStr"/>

    <!-- Base Colors -->
    <!-- Dark Theme -->
    <Color x:Key="DarkBgColor">#1E1E1E</Color>
    <Color x:Key="DarkSurfaceColor">#2D2D2D</Color>
    <Color x:Key="DarkControlBgColor">#3C3C3C</Color>
    <Color x:Key="DarkBorderColor">#444444</Color>
    <Color x:Key="DarkTextColor">#E0E0E0</Color>
    <Color x:Key="DarkTextSecondaryColor">#AAAAAA</Color>

    <!-- Light Theme -->
    <Color x:Key="LightBgColor">#F2F2F2</Color>
    <Color x:Key="LightSurfaceColor">#FFFFFF</Color>
    <Color x:Key="LightControlBgColor">#FFFFFF</Color>
    <Color x:Key="LightBorderColor">#D1D1D1</Color>
    <Color x:Key="LightTextColor">#1E1E1E</Color>
    <Color x:Key="LightTextSecondaryColor">#666666</Color>

    <Color x:Key="AccentColor">#0078D4</Color>

    <!-- Theme-aware brushes -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource DarkBgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource DarkSurfaceColor}"/>
    <SolidColorBrush x:Key="ControlBgBrush" Color="{StaticResource DarkControlBgColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource DarkBorderColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource DarkTextColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource DarkTextSecondaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="OrangeBrush" Color="{StaticResource OrangeColor}"/>

    <!-- Light theme brushes -->
    <SolidColorBrush x:Key="DarkBg" Color="{StaticResource DarkBgColor}"/>
    <SolidColorBrush x:Key="DarkSurface" Color="{StaticResource DarkSurfaceColor}"/>
    <SolidColorBrush x:Key="DarkControlBg" Color="{StaticResource DarkControlBgColor}"/>
    <SolidColorBrush x:Key="DarkBorder" Color="{StaticResource DarkBorderColor}"/>
    <SolidColorBrush x:Key="DarkText" Color="{StaticResource DarkTextColor}"/>
    <SolidColorBrush x:Key="DarkTextSecondary" Color="{StaticResource DarkTextSecondaryColor}"/>
    <SolidColorBrush x:Key="LightBg" Color="{StaticResource LightBgColor}"/>
    <SolidColorBrush x:Key="LightSurface" Color="{StaticResource LightSurfaceColor}"/>
    <SolidColorBrush x:Key="LightControlBg" Color="{StaticResource LightControlBgColor}"/>
    <SolidColorBrush x:Key="LightBorder" Color="{StaticResource LightBorderColor}"/>
    <SolidColorBrush x:Key="LightText" Color="{StaticResource LightTextColor}"/>
    <SolidColorBrush x:Key="LightTextSecondary" Color="{StaticResource LightTextSecondaryColor}"/>

    <SolidColorBrush x:Key="TabHoverBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#666666"/>

</ResourceDictionary>
